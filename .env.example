# D-Strategies environment — copy to .env and fill in secrets

# ── Database (TimescaleDB) ────────────────────────────────────────────────────
DB_HOST=localhost
DB_PORT=5432
DB_USER=dstrategies
DB_PASSWORD=changeme
DB_NAME=dstrategies

# ── Redis ────────────────────────────────────────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379

# ── Broker ───────────────────────────────────────────────────────────────────
PAPER_MODE=true          # true = paper broker, false = live venues
BROKER_API_KEY=
BROKER_API_SECRET=

# ── Engine ───────────────────────────────────────────────────────────────────
CAPITAL=1000000          # starting capital in INR
AGGREGATOR_MODE=vol      # equal | vol | score
SIGNAL_AGE_MS=30000

# ── Notifications ────────────────────────────────────────────────────────────
TELEGRAM_TOKEN=
TELEGRAM_CHAT_ID=
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
ALERT_EMAIL_TO=

# ── Logging ──────────────────────────────────────────────────────────────────
LOG_LEVEL=info           # debug | info | warning | error | critical

# ── Frontend ─────────────────────────────────────────────────────────────────
FRONTEND_PORT=3000
API_PORT=8000
